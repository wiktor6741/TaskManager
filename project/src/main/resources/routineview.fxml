<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"  fx:controller="controllers.RoutineViewController" fx:id="stackPane">
    <children>
        <BorderPane styleClass="BorderPane">
            <top>
                <VBox>
                    <HBox prefHeight="70" alignment="center" spacing="15">
                        <padding>
                            <Insets top="10" right="20" bottom="10" left="20"/>
                        </padding>
                        <Button text="◀ Task Menu" fx:id="backButton"/>
                        <ComboBox fx:id="routineComboBox"/>
                        <Button text="Edit this routine" fx:id="routineEditButton"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="◀" fx:id="weekDownButton"/>
                        <Label text="Week 1" fx:id="weekNumLabel"/>
                        <Button text="▶" fx:id="weekUpButton"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="New Routine" maxHeight="Infinity" fx:id="newRoutineButton"/>
                        <Button text="Routine Elements" maxHeight="Infinity" fx:id="elementButton"/>
                        <Button text="Insert element"  maxHeight="Infinity" fx:id="insertElementButton"/>
                    </HBox>
                    <HBox>
                        <Region prefWidth="50" minWidth="50"/>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0" maxWidth="Infinity">
                            <Label text="MON">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS"  prefWidth="0" maxWidth="Infinity">
                            <Label text="TUE">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0"  maxWidth="Infinity">
                            <Label text="WED">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0"  maxWidth="Infinity">
                            <Label text="THU">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0" maxWidth="Infinity">
                            <Label text="FRI">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0" maxWidth="Infinity">
                            <Label text="SAT">
                            </Label>
                        </HBox>
                        <HBox styleClass="weekday-box" HBox.hgrow="ALWAYS" prefWidth="0" maxWidth="Infinity">
                            <Label text="SUN">
                            </Label>
                        </HBox>
                        <Region prefWidth="15"/>
                    </HBox>
                    <Region prefHeight="10"/>
                </VBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" fx:id="scrollPane">
                    <content>
                        <Pane fx:id="dayColumn"/>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</StackPane>